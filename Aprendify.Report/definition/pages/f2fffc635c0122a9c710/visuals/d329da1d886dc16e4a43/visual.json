            "paragraphs": [
              {
                "textRuns": [
                  {
                    "value": "El progreso en los cursos es el principal indicador de fidelización",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "14pt"
                    }
                  }
                ],
                "horizontalTextAlignment": "center"
              },
              {
                "textRuns": [
                  {
                    "value": "Los resultados muestran que los usuarios "
                  },
                  {
                    "value": "Premium presentan una tasa de completitud significativamente mayor (70.57%)",
                    "textStyle": {
                      "fontWeight": "bold"
                    }
                  },
                  {
                    "value": " que los usuarios del plan Básico (59.84%) y también una "
                  },
                  {
                    "value": "mayor intención de renovación (71.94% frente a 58.59%)",
                    "textStyle": {
                      "fontWeight": "bold"
                    }
                  },
                  {
                    "value": "."
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Sin embargo, ambos grupos presentan "
                  },
                  {
                    "value": "niveles de uso semanal prácticamente iguales",
                    "textStyle": {
                      "fontWeight": "bold"
                    }
                  },
                  {
                    "value": ". Esto sugiere que la fidelización de los usuarios no depende tanto del tiempo que pasan en la plataforma, sino del "
                  },
                  {
                    "value": "progreso efectivo que logran en los cursos",
                    "textStyle": {
                      "fontWeight": "bold"
                    }
                  },
                  {
                    "value": "."
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Insight clave: ",
                    "textStyle": {
                      "fontWeight": "bold"
                    }
                  },
                  {
                    "value": "La finalización de cursos es un factor más determinante para la fidelización que el tiempo de uso de la plataforma."
                  }
                ]
              }
            ]
          }
        }
      ]
